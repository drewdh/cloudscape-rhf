{
  "name": "cloudscape-rhf",
  "version": "0.1.0",
  "description": "React Hook Form wrappers for Cloudscape Design System components",
  "keywords": [
    "cloudscape",
    "react-hook-form",
    "rhf",
    "aws",
    "form",
    "react"
  ],
  "author": "Drew Hanberry",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/drewhanberry/cloudscape-rhf.git"
  },
  "homepage": "https://github.com/drewhanberry/cloudscape-rhf#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@cloudscape-design/components": ">=3",
    "react": ">=18",
    "react-hook-form": ">=7"
  },
  "devDependencies": {
    "@cloudscape-design/global-styles": "^1.0.58",
    "@chromatic-com/storybook": "^5.1.2",
    "@cloudscape-design/components": "^3.0.1255",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/react": "^19.0.0",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "playwright": "^1.59.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.74.0",
    "storybook": "^10.3.6",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
